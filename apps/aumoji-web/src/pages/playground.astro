---
import Main from '../layouts/Main.astro'
import PopupDemo from '../components/PopupDemo.vue'
---

<Main title="演示 · AUmoji">
  <section class="playground">
    <div class="container">
      <h1>互动演示</h1>
      <p class="subtitle">点击下方按钮打开表情选择器</p>
      
      <PopupDemo client:load />

      <div class="info-box">
        <h3>💡 提示</h3>
        <p>这是一个实时演示。选择表情后，会在右侧面板显示完整信息。</p>
      </div>
    </div>
  </section>
</Main>

<style>
  .playground {
    min-height: calc(100vh - 200px);
    padding: 60px 20px;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .playground h1 {
    text-align: center;
    margin-bottom: 12px;
    font-size: 2.5rem;
  }

  .subtitle {
    text-align: center;
    font-size: 1.1rem;
    color: var(--tx2);
    margin-bottom: 48px;
  }

  .info-box {
    margin-top: 48px;
    background: var(--ac-soft);
    border: 1px solid var(--ac-bd);
    border-radius: 8px;
    padding: 20px;
  }

  .info-box h3 {
    margin-bottom: 8px;
    color: var(--ac);
  }

  .info-box p {
    margin: 0;
    color: var(--tx2);
  }
</style>
