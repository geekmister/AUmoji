---
import { getCollection } from 'astro:content'
import Main from '../../layouts/Main.astro'

export async function getStaticPaths() {
  const docs = await getCollection('docs')
  return docs.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }))
}

interface Props {
  entry: any
}

const { entry } = Astro.props as Props
const { Content } = await entry.render()
---

<Main title={entry.data.title} description={entry.data.description}>
  <section class="doc-page">
    <div class="container">
      <div class="doc-nav">
        <a href="/docs">← 返回文档</a>
      </div>
      
      <article class="doc-article">
        <header class="doc-header">
          <h1>{entry.data.title}</h1>
          {entry.data.description && <p class="subtitle">{entry.data.description}</p>}
        </header>
        
        <div class="doc-content">
          <Content />
        </div>
      </article>
    </div>
  </section>
</Main>

<style>
  .doc-page {
    min-height: calc(100vh - 200px);
    padding: 40px 20px;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
  }

  .doc-nav {
    margin-bottom: 32px;
  }

  .doc-nav a {
    font-size: 14px;
    color: var(--ac);
    text-decoration: none;
    transition: color var(--ease);
  }

  .doc-nav a:hover {
    color: var(--ac2);
  }

  .doc-header {
    margin-bottom: 40px;
    border-bottom: 1px solid var(--divider);
    padding-bottom: 24px;
  }

  .doc-header h1 {
    margin-bottom: 12px;
    font-size: 2.5rem;
  }

  .subtitle {
    font-size: 1.1rem;
    color: var(--tx2);
    margin: 0;
  }

  .doc-article h2 {
    margin-top: 40px;
    margin-bottom: 16px;
    font-size: 1.75rem;
  }

  .doc-article h3 {
    margin-top: 32px;
    margin-bottom: 12px;
    font-size: 1.25rem;
  }

  .doc-article p {
    margin-bottom: 1.5rem;
    line-height: 1.8;
  }

  .doc-article ul,
  .doc-article ol {
    margin-bottom: 1.5rem;
  }

  .doc-article li {
    margin-bottom: 0.75rem;
  }

  .doc-article code {
    background: var(--card);
    padding: 2px 6px;
    border-radius: 4px;
    font-family: 'Menlo', 'Monaco', 'Courier New', monospace;
    font-size: 0.9em;
  }

  .doc-article pre {
    margin-bottom: 1.5rem;
    overflow-x: auto;
  }

  .doc-article table {
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  .doc-article blockquote {
    margin: 1.5rem 0;
    padding-left: 1rem;
  }
</style>
