---
import { getCollection } from 'astro:content'
import Main from '../../layouts/Main.astro'

const docs = await getCollection('docs')
const docList = docs.sort((a, b) => a.slug.localeCompare(b.slug))
---

<Main title="文档 · AUmoji">
  <section class="docs-index">
    <div class="container">
      <h1>文档</h1>
      <p class="subtitle">AUmoji 完整指南和参考手册</p>

      <div class="docs-grid">
        {docList.map((doc) => (
          <a href={`/docs/${doc.slug}`} class="doc-card">
            <h3>{doc.data.title}</h3>
            <p>{doc.data.description}</p>
            <span class="arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Main>

<style>
  .docs-index {
    min-height: calc(100vh - 200px);
    padding: 60px 20px;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .docs-index h1 {
    text-align: center;
    margin-bottom: 12px;
    font-size: 2.5rem;
  }

  .subtitle {
    text-align: center;
    font-size: 1.1rem;
    color: var(--tx2);
    margin-bottom: 48px;
  }

  .docs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
  }

  .doc-card {
    background: var(--card);
    border: 1px solid var(--card-bd);
    border-radius: 8px;
    padding: 24px;
    text-decoration: none;
    transition: all 0.14s ease;
    position: relative;
    display: block;
  }

  .doc-card:hover {
    border-color: var(--ac-bd);
    background: rgba(124, 58, 237, 0.06);
    transform: translateY(-4px);
  }

  .doc-card h3 {
    margin-bottom: 8px;
    font-size: 1.25rem;
    color: var(--ac);
  }

  .doc-card p {
    color: var(--tx2);
    font-size: 0.95rem;
    margin: 0 0 16px 0;
    line-height: 1.5;
  }

  .arrow {
    font-size: 20px;
    color: var(--ac);
    display: inline-block;
    opacity: 0;
    transition: opacity 0.14s ease, transform 0.14s ease;
  }

  .doc-card:hover .arrow {
    opacity: 1;
    transform: translateX(4px);
  }
</style>
